# Servidor
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Banco de dados (PostgreSQL via Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/controle_estoque?schema=public

# Autenticação
JWT_SECRET=troque-este-valor-por-um-segredo-forte-e-aleatorio
JWT_EXPIRES_IN=7d

# CORS — origem do front-end (use "*" em dev, ou domínios separados por vírgula)
CORS_ORIGIN=http://localhost:5173

# Upload de imagens de produtos
UPLOAD_DIR=uploads/products
MAX_UPLOAD_SIZE_MB=5
